        label=fr"MUSCL fit  (slope $b={b_m:.3f}$)")
print(f"MUSCL ALL: slope={b_m:.4f}, crossing at {tc_m:.1f} s")

# threshold
t_range = [min(ader_all["runtime_sec"].min(), muscl_all["runtime_sec"].min()) * 0.3,
