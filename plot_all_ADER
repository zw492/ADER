# 3.2  Riemann tests

def plot_riemann(test_name, Tout, x0):
    a3 = pd.read_csv(DATA + f"{test_name}_ADER3.csv")
    mu = pd.read_csv(DATA + f"{test_name}_MUSCL.csv")

    var_cols   = ["rho",                 "u",                 "p"]
    var_labels = [r"Density $\rho$",    r"Velocity $u$",     r"Pressure $p$"]

    fig, axes = plt.subplots(1, 3, figsize=(14, 4.2))
    for ax, vc, vl in zip(axes, var_cols, var_labels):
        ax.plot(a3["x"], a3[f"{vc}_ex"],  color=COL_EXACT, lw=2.2,
                label="Exact", zorder=3)
        ax.plot(mu["x"], mu[f"{vc}_num"], color=COL_MUSCL, lw=1.2, ls="--",
                label="MUSCL (MC)", zorder=2)
        ax.plot(a3["x"], a3[f"{vc}_num"], color=COL_ADER3, lw=1.2, ls="-",
                label="ADER3", zorder=2)
        ax.set_xlabel(r"$x$")
        ax.set_ylabel(vl)
        ax.set_title(vl)
        ax.legend(fontsize=8.5)
        ax.grid(True, ls=":", alpha=0.4)

    plt.suptitle(
        f"Task 3.2: {test_name} test — $N=200$, $T_{{\\rm out}}={Tout}$, $x_0={x0}$",
        fontsize=12, y=1.02)
    plt.tight_layout()
    fname = OUT + f"fig_3_2_{test_name.lower()}.png"
    plt.savefig(fname, bbox_inches="tight")
    plt.close()
    print(f"Saved {fname}")

