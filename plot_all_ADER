# log-log convergence plot
fig, axes = plt.subplots(1, 3, figsize=(13, 4.5))
norm_cols   = ["L1",     "L2",     "Linf"]
norm_labels = [r"$L^1$", r"$L^2$", r"$L^\infty$"]

for ax, nc, nl in zip(axes, norm_cols, norm_labels):
    for scheme, col, mk, ls in [("MUSCL", COL_MUSCL, "s", "--"),
                                ("ADER3", COL_ADER3, "o", "-")]:
        sub = cv[cv.scheme == scheme].sort_values("N")
        ax.loglog(sub["dx"], sub[nc], color=col, marker=mk,
                  linestyle=ls, label=scheme, markersize=5)

    # Reference slopes anchored at data midpoints
    dx_all = cv["dx"].values
    dx_ref = np.logspace(np.log10(dx_all.min()*0.8), np.log10(dx_all.max()*1.2), 50)
    for p, scheme_ref, col in [(2, "MUSCL", COL_MUSCL), (3, "ADER3", COL_ADER3)]:
        sub = cv[cv.scheme == scheme_ref].sort_values("N")
        mid = len(sub)//2
        c = sub[nc].iloc[mid] / sub["dx"].iloc[mid]**p
        ax.loglog(dx_ref, c * dx_ref**p, color=col, ls=":", alpha=0.55,
                  lw=1.1, label=f"$O(\\Delta x^{p})$")

    ax.set_xlabel(r"$\Delta x$")
    ax.set_ylabel(f"Density error ({nl})")
    ax.set_title(f"{nl} norm")
    ax.legend(fontsize=8)
    ax.grid(True, which="both", ls=":", alpha=0.45)

plt.suptitle(r"Task 3.1: Convergence — $T_{\rm out}=2$, problem (1)", fontsize=12, y=1.02)
plt.tight_layout()
