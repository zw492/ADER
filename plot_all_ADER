# 3.1  Convergence table + log-log plot

cv = pd.read_csv(DATA + "convergence_table_T2.csv")

def fmt_rate(v):
    return "—" if (isinstance(v, float) and np.isnan(v)) else f"{v:.2f}"

def fmt_sci(v):
    return f"{v:.3e}"

rows_muscl = cv[cv.scheme == "MUSCL"].reset_index(drop=True)
rows_ader  = cv[cv.scheme == "ADER3"].reset_index(drop=True)
rows_order = pd.concat([rows_muscl, rows_ader], ignore_index=True)

col_labels = ["Scheme", "N", r"$\Delta x$",
              r"$\|e\|_{L^1}$", r"$r_{L^1}$",
              r"$\|e\|_{L^2}$", r"$r_{L^2}$",
              r"$\|e\|_{L^\infty}$", r"$r_{L^\infty}$"]

table_data = []
for _, row in rows_order.iterrows():
    table_data.append([
        row["scheme"],
        int(row["N"]),
        fmt_sci(row["dx"]),
        fmt_sci(row["L1"]),   fmt_rate(row["rate_L1"]),
        fmt_sci(row["L2"]),   fmt_rate(row["rate_L2"]),
        fmt_sci(row["Linf"]), fmt_rate(row["rate_Linf"]),
    ])

fig, ax = plt.subplots(figsize=(14, 4.4))
ax.axis("off")
tbl = ax.table(cellText=table_data, colLabels=col_labels,
               cellLoc="center", loc="center")
tbl.auto_set_font_size(False)
tbl.set_fontsize(9.5)
tbl.scale(1, 1.6)

for j in range(len(col_labels)):
    tbl[(0, j)].set_facecolor("#2c3e50")
    tbl[(0, j)].set_text_props(color="white", fontweight="bold")

n_muscl = len(rows_muscl)
for i, row in enumerate(rows_order.itertuples(), start=1):
    colour = "#dce9f7" if row.scheme == "ADER3" else "#fde8e8"
    for j in range(len(col_labels)):
        tbl[(i, j)].set_facecolor(colour)

