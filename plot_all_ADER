# 3.4B  Efficiency log-log plot
eff = pd.read_csv(DATA + "Efficiency_T100.csv")
ader_all  = eff[eff.scheme == "ADER3"].sort_values("N").reset_index(drop=True)
muscl_all = eff[eff.scheme == "MUSCL"].sort_values("N").reset_index(drop=True)

TARGET = 1e-3

def fit_loglog(err_arr, time_arr, target):
    """Returns (err_plot, t_plot, slope, t_cross) where axes are (time, error)."""
    lx = np.log10(err_arr)
    ly = np.log10(time_arr)
    b, a, *_ = linregress(lx, ly)
    t_cross = 10.0 ** (a + b * np.log10(target))
    err_plot = np.logspace(np.log10(target * 0.3),
                           np.log10(err_arr.max() * 1.5), 200)
    t_plot   = 10.0 ** (a + b * np.log10(err_plot))
    return err_plot, t_plot, b, t_cross

fig, ax = plt.subplots(figsize=(9, 6.5))

# scatter data points
ax.scatter(ader_all["runtime_sec"], ader_all["L2_rho"],
           color=COL_ADER3, marker="o", s=55, zorder=6, label="ADER3 data")
ax.scatter(muscl_all["runtime_sec"], muscl_all["L2_rho"],
           color=COL_MUSCL, marker="s", s=55, zorder=6, label="MUSCL data")

# Annotate N values
for _, row in ader_all.iterrows():
    ax.annotate(f"N={int(row.N)}", (row.runtime_sec, row.L2_rho),
                textcoords="offset points", xytext=(5, 3),
                fontsize=7, color=COL_ADER3, zorder=7)
for _, row in muscl_all.iterrows():
    ax.annotate(f"N={int(row.N)}", (row.runtime_sec, row.L2_rho),
                textcoords="offset points", xytext=(5, -11),
                fontsize=7, color=COL_MUSCL, zorder=7)

# ADER3 fit using all points
ep_a, tp_a, b_a, tc_a = fit_loglog(ader_all["L2_rho"].values,
                                   ader_all["runtime_sec"].values, TARGET)
ax.plot(tp_a, ep_a, color=COL_ADER3, lw=1.8, ls="-",
        label=fr"ADER3 fit  (slope $b={b_a:.3f}$)")
print(f"ADER3 ALL: slope={b_a:.4f}, crossing at {tc_a:.1f} s")

# MUSCL fit using all points
